# Example Environment Variables for Meet Me Halfway v2
# Copy this file to .env.local and fill in your secrets/keys

#########################
# DATABASE (Supabase)
#########################
DATABASE_URL= # PostgreSQL connection string (required)
NEXT_PUBLIC_SUPABASE_URL= # Supabase project URL (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Supabase publishable (sb_publishable_...) or legacy anon JWT (client-safe)
SUPABASE_SECRET_KEY= # Supabase secret key (sb_secret_...); server-only, never NEXT_PUBLIC_
# SUPABASE_SERVICE_ROLE_KEY= # Legacy JWT service_role; deprecated — use SUPABASE_SECRET_KEY

#########################
# AUTHENTICATION (Clerk)
#########################
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= # Clerk frontend key (required)
CLERK_SECRET_KEY= # Clerk backend secret key (required)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login # (optional, default: /login)
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup # (optional, default: /signup)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/meet-me-halfway # (optional)
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/meet-me-halfway # (optional)
NEXT_PUBLIC_CLERK_DEVELOPMENT_DOMAIN=localhost:3000 # (optional, for local dev)

#########################
# PAYMENTS (Stripe)
#########################
STRIPE_SECRET_KEY= # Stripe secret key (optional, for payments)
STRIPE_WEBHOOK_SECRET= # Stripe webhook secret (optional)
NEXT_PUBLIC_STRIPE_PORTAL_LINK= # (optional)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_YEARLY= # (optional)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_MONTHLY= # (optional)

#########################
# ANALYTICS & MONITORING (PostHog)
#########################
POSTHOG_API_KEY= # Backend PostHog project API key (required for backend analytics)
POSTHOG_HOST=https://app.posthog.com # PostHog host (default)
NEXT_PUBLIC_POSTHOG_KEY= # Frontend PostHog project API key (required for frontend analytics)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com # (default)

#########################
# ERROR TRACKING (Sentry — web)
#########################
NEXT_PUBLIC_SENTRY_DSN= # Sentry DSN (required in production for error capture)
SENTRY_DSN= # Optional server duplicate; can match NEXT_PUBLIC_SENTRY_DSN
SENTRY_ENABLED=false # Set true in .env.local to test Sentry in development
# Vercel (v0-meet-me-halfway2): install Sentry integration or set for source map uploads at build time
SENTRY_ORG=meetmehalfway
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=

#########################
# MEET-ME-HALFWAY SPECIFIC
#########################
OPENROUTESERVICE_API_KEY= # OpenRouteService API key (required)
LOCATIONIQ_KEY= # LocationIQ API key (required)

#########################
# API SECURITY
#########################
API_KEY= # (optional, for custom API security)

#########################
# RATE LIMITING (Upstash Redis)
#########################
UPSTASH_REDIS_REST_URL= # Upstash Redis REST URL (required)
UPSTASH_REDIS_REST_TOKEN= # Upstash Redis REST token (required)

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=10 # Max requests per window (anonymous)
RATE_LIMIT_WINDOW=10 # Window in seconds (anonymous)
RATE_LIMIT_REQUESTS_AUTH=50 # Max requests per window (authenticated)
RATE_LIMIT_WINDOW_AUTH=60 # Window in seconds (authenticated)
RATE_LIMIT_REQUESTS_SPECIAL=100 # Max requests per window (special endpoints)
RATE_LIMIT_WINDOW_SPECIAL=60 # Window in seconds (special endpoints)

#########################
# API RESPONSE CACHE (Upstash Redis)
#########################
# Caches POI search, geocode, and coordinate-snap responses to reduce LocationIQ usage.
API_CACHE_ENABLED=true # Set to false to disable caching
POI_CACHE_TTL_SECONDS=43200 # 12 hours
GEOCODE_CACHE_TTL_SECONDS=86400 # 24 hours
SNAP_CACHE_TTL_SECONDS=86400 # 24 hours
POI_CACHE_GRID_DECIMALS=4 # Coordinate bucket size (~11m at 4 decimals)


# Pro Features Toggle
# Set to true to enable Pro features globally for UI development/testing (bypasses plan checks in some UI locations)
# THIS IS MAINLY FOR DEVELOPMENT AND UI PREVIEW. PRODUCTION LOGIC SHOULD RELY ON ACTUAL USER PLAN.
NEXT_PUBLIC_ENABLE_PRO_FEATURES=false

#########################
# GEO / ROUTING (additional providers)
#########################
RAPIDAPI_FAST_ROUTING_HOST= # RapidAPI OSRM host (optional)
RAPIDAPI_FAST_ROUTING_KEY= # RapidAPI OSRM key (optional)
HERE_API_KEY= # HERE API key for Pro traffic routing (optional)

#########################
# SECRET ROTATION (production hygiene)
#########################
# Rotate in the provider dashboard, then update Vercel env vars (v0-meet-me-halfway2).
# Redeploy is required after changing server-side secrets.
#
# | Secret / key                         | Where to rotate              | Cadence (low traffic) | Notes |
# |--------------------------------------|------------------------------|------------------------|-------|
# | CLERK_SECRET_KEY                     | Clerk Dashboard → API Keys   | Annually or on leak    | Also rotate webhook signing secret if compromised |
# | NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY    | Clerk (only if rotating app) | Rare                   | Public; rotate with secret key pair |
# | STRIPE_SECRET_KEY                    | Stripe Dashboard → API keys  | Annually or on leak    | Use restricted keys when possible |
# | STRIPE_WEBHOOK_SECRET                | Stripe → Webhooks → endpoint | On endpoint recreate   | Update Vercel + redeploy |
# | SUPABASE_SECRET_KEY                  | Supabase → Settings → API Keys | On leak only         | Server-only; never NEXT_PUBLIC_ |
# | NEXT_PUBLIC_SUPABASE_ANON_KEY        | Supabase → Settings → API    | Rare                   | Public; RLS must protect data |
# | DATABASE_URL                         | Supabase → Database settings | On leak / pooler change| Updates connection string |
# | UPSTASH_REDIS_REST_TOKEN             | Upstash → database → REST    | On leak only           | Pair with UPSTASH_REDIS_REST_URL |
# | LOCATIONIQ_KEY                       | LocationIQ account           | Annually or quota abuse| Geocoding + POI |
# | RAPIDAPI_FAST_ROUTING_KEY            | RapidAPI → app → key         | Annually or on leak    | OSRM routing |
# | OPENROUTESERVICE_API_KEY             | openrouteservice.org dev keys| Annually or on leak    | Matrix / fallback routing |
# | HERE_API_KEY                         | HERE developer portal        | Annually or on leak    | Pro tier traffic matrix |
# | POSTHOG_API_KEY / NEXT_PUBLIC_POSTHOG_KEY | PostHog → Project settings | On leak only      | Separate keys for server vs client |
# | NEXT_PUBLIC_SENTRY_DSN / SENTRY_DSN  | Sentry → Project → Client Keys | On leak only         | Regenerate DSN; SENTRY_AUTH_TOKEN via Vercel integration |
# | SENTRY_AUTH_TOKEN                    | Sentry → Auth tokens         | Annually               | Build-time source maps only |
# | API_KEY                              | Your own rotation policy     | As needed              | Custom API security if enabled |
#
# PostHog product analytics and Sentry error tracking are intentionally separate—do not merge dashboards.