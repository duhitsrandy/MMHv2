{
  "name": "mmh-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "kill-port 3000 >/dev/null 2>&1 || true && next dev",
    "dev:https": "kill-port 3000 || true && NODE_TLS_REJECT_UNAUTHORIZED=0 next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "npm run lint:fix && npm run format:write",
    "type-check": "tsc --noEmit",
    "lint:fix": "next lint --fix",
    "format:write": "prettier --write \"{app,lib,db,components,context,types}/**/*.{ts,tsx}\" --cache",
    "format:check": "prettier --check \"{app,lib,db,components,context,types}**/*.{ts,tsx}\" --cache",
    "analyze": "ANALYZE=true npm run build",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "prepare": "husky install",
    "docs:index": "node scripts/generate-docs-index.cjs",
    "mobile:check-env": "node ./scripts/verify-mobile-env.cjs",
    "mobile:preflight": "npm run mobile:check-env && cd MeetMeHalfwayMobile && npx expo-doctor && npx tsc --noEmit",
    "mobile:sync-env": "node ./scripts/sync-mobile-env.cjs",
    "mobile:start": "npm run mobile:check-env && npm run --prefix ./MeetMeHalfwayMobile start",
    "mobile:ios": "npm run --prefix ./MeetMeHalfwayMobile ios",
    "mobile:ios:reset": "npm run --prefix ./MeetMeHalfwayMobile ios:reset-sim",
    "mobile:dev": "npm run mobile:check-env && npm run mobile:ios",
    "mobile:eas-env": "node ./scripts/generate-eas-production-env.cjs && cd MeetMeHalfwayMobile && npx eas-cli env:push production --path .env.eas-production --force",
    "mobile:eas-build": "cd MeetMeHalfwayMobile && npx eas-cli build --profile production --platform ios",
    "mobile:eas-submit": "cd MeetMeHalfwayMobile && npx eas-cli submit --platform ios --latest",
    "xcode:check": "xcode-select -p && xcrun simctl help >/dev/null 2>&1 && echo 'Xcode CLI OK' || echo 'Xcode CLI issue — run: sudo xcode-select --reset'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clerk/backend": "^2.0.0",
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@clerk/nextjs": "^6.12.0",
    "@clerk/themes": "^2.2.23",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/supabase-js": "^2.49.1",
    "@types/lodash": "^4.17.16",
    "@types/lodash.debounce": "^4.0.9",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv-safe": "^9.1.0",
    "drizzle-orm": "^0.42.0",
    "embla-carousel-react": "^8.5.1",
    "framer-motion": "^11.11.8",
    "input-otp": "^1.4.1",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "lru-cache": "^11.1.0",
    "lucide-react": "^0.436.0",
    "next": "^15.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.14.0",
    "postgres": "^3.4.4",
    "posthog-js": "^1.234.6",
    "posthog-node": "^4.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.6.7",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.1",
    "react-leaflet": "^5.0.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.0",
    "sonner": "^1.7.1",
    "stripe": "^16.9.0",
    "svix": "^1.64.1",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.2.4",
    "@tailwindcss/typography": "^0.5.15",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^3.1.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^8",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "husky": "^9.1.6",
    "jsdom": "^26.0.0",
    "kill-port": "^2.0.1",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.1"
  }
}
